{
  "name": "NemoClaw",
  "version": "0.3.0",
  "slug": "nemoclaw",
  "description": "Locked-down OpenClaw financial agent with portfolio monitoring skills. Connects to Telegram via @TheWolfAdvisor_bot.",
  "url": "https://github.com/JeremyTChase/nemoclaw-ha-addon",
  "arch": ["aarch64", "amd64"],
  "startup": "services",
  "boot": "auto",
  "host_network": true,
  "hassio_api": false,
  "homeassistant_api": false,
  "map": ["config:rw", "share:rw"],
  "environment": {
    "HOME": "/config/nemoclaw",
    "GH_CONFIG_DIR": "/config/nemoclaw/.config/gh"
  },
  "options": {
    "install_mode": "package",
    "port": 18790,
    "verbose": false,
    "repo_url": "https://github.com/openclaw/openclaw.git",
    "branch": "",
    "github_token": "",
    "telegram_bot_token": "",
    "telegram_chat_id": "-5290115098",
    "telegram_user_id": "6230203869",
    "vllm_base_url": "http://192.168.6.241:8000/v1",
    "vllm_model": "nvidia/Qwen3-Next-80B-A3B-Instruct-NVFP4",
    "portfolio_db_path": "/share/portfolio-dashboard/portfolio.db",
    "timezone": "Europe/London"
  },
  "schema": {
    "install_mode": "list(package|source)",
    "port": "int(1,65535)",
    "verbose": "bool",
    "repo_url": "str",
    "branch": "str?",
    "github_token": "password?",
    "telegram_bot_token": "password",
    "telegram_chat_id": "str",
    "telegram_user_id": "str",
    "vllm_base_url": "url",
    "vllm_model": "str",
    "portfolio_db_path": "str",
    "timezone": "str"
  }
}
